# Secrets live OUTSIDE the evaluation config (Foundry FR-127).
# Copy to secrets.env (gitignored) and fill in only what your backend needs.

# Required only for the Anthropic API backend (FOUNDRY_LLM_BACKEND=api):
ANTHROPIC_API_KEY=

# Select the LLM backend without editing evaluation.yaml:
#   stub  -> deterministic, offline (default)
#   cli   -> uses the local `claude -p` CLI
#   api   -> uses the Anthropic API (needs ANTHROPIC_API_KEY)
FOUNDRY_LLM_BACKEND=stub
